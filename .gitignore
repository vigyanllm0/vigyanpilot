# ── Python ────────────────────────────────────────────────────────────────
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# ── Secrets & credentials (NEVER commit) ──────────────────────────────────
.env
.env.*
!.env.example
infra/.env.app
infra/.env.postgres
config/ncbi_api_key.txt
*.pem
*.key
*.p12
*.pfx

# ── Local databases ────────────────────────────────────────────────────────
primerforge.db
*.db
*.sqlite
*.sqlite3

# ── OS / IDE ───────────────────────────────────────────────────────────────
.DS_Store
.vscode/
.kiro/

# ── Large binary / media files ─────────────────────────────────────────────
# *.mp4  — removed to allow demo videos
*.mov
*.avi

# ── QA run artifacts (large BLAST/Bowtie2 binary indexes) ─────────────────
qa_runs/*/blast/
qa_runs/*/bowtie2/
qa_runs/*/*.vcf.gz
qa_runs/*/*.vcf.gz.tbi
qa_runs/*/*.fa

# ── NCBI BLAST binaries (too large, install on server) ────────────────────
tools/

# ── Python compiled cache ─────────────────────────────────────────────────
infra/scripts/__pycache__/
scripts/__pycache__/
tests/__pycache__/

# ── Security artifacts (internal only) ────────────────────────────────────
SECURITY_REPORT.md
.file_integrity_baseline.json
security_audit.py

# ── Server logs ────────────────────────────────────────────────────────────
*.log

# ── Backend URL config (per-developer, ngrok URL changes each run) ────────
frontend/config.js

# ── Node.js (accidental root install / local dev) ──────────────────────────
node_modules/
package-lock.json

# ── Uploaded logo (raw file, keep only processed version) ─────────────────
frontend/2DxRE.svg

# ── CMS uploads ────────────────────────────────────────────────────────────
frontend/uploads/cms/
