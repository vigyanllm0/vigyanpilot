# ────────────────────────────────────────────────────────────────────────────
# VigyanLLM Azure Worker Container
# ==================================
# Designed to run on Azure Container Instances (ACI) for heavy computational
# workloads that would OOM the main EC2 t3.micro instance.
#
# Build:
#   docker build -t vigyanllm-azure-worker -f azure_worker/Dockerfile.azure .
#
# Push to Azure Container Registry:
#   az acr login --name vigyanregistry01
#   docker tag vigyanllm-azure-worker vigyanregistry01.azurecr.io/vigyan-worker:latest
#   docker push vigyanregistry01.azurecr.io/vigyan-worker:latest
#
# Run on ACI:
#   az container create \
#     --resource-group VigyanComputeGroup \
#     --name vigyan-high-perf-worker \
#     --image vigyanregistry01.azurecr.io/vigyan-worker:latest \
#     --cpu 4 --memory 8 \
#     --environment-variables \
#       API_BASE_URL=https://www.vigyanllm.in \
#       POLL_INTERVAL=15 \
#     --command-line "python /app/azure_worker/worker.py --daemon"
#
# ────────────────────────────────────────────────────────────────────────────

FROM python:3.11-slim AS base

# Prevent Python from writing .pyc files and buffering stdout
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    DEBIAN_FRONTEND=noninteractive \
    TORCH_LOAD_MMAP=0

# Enable non-free repository for vienna-rna
RUN sed -i 's/Components: main/Components: main contrib non-free/g' /etc/apt/sources.list.d/debian.sources || sed -i 's/main/main contrib non-free/g' /etc/apt/sources.list

# Install system dependencies for bioinformatics tools + molecular docking
RUN apt-get update && apt-get install -y --no-install-recommends \
    autodock-vina \
    bowtie2 \
    build-essential \
    ca-certificates \
    curl \
    mafft \
    ncbi-blast+ \
    openbabel \
    primer3 \
    samtools \
    tabix \
    vienna-rna \
    && rm -rf /var/lib/apt/lists/*

# Download GNINA binary (CNN docking scorer) — pre-built Linux binary from GitHub
# GNINA v1.3 — asset name is just "gnina" (v1.3.2 renamed to "gnina.1.3.2")
RUN curl -fsSL https://github.com/gnina/gnina/releases/download/v1.3/gnina -o /usr/local/bin/gnina \
    && chmod +x /usr/local/bin/gnina

WORKDIR /app

# Copy and install Python dependencies first (for Docker layer caching)
COPY requirements.txt requirements-docking.txt ./
RUN pip install --no-cache-dir -r requirements.txt
# Install CPU-only torch (no CUDA toolkit — ACI has no GPU)
RUN pip install --no-cache-dir --index-url https://download.pytorch.org/whl/cpu "torch>=2.2.0" && \
    pip install --no-cache-dir transformers>=4.40.0 tokenizers>=0.15.0 fair-esm>=2.0.0 \
                          einops>=0.6.0 accelerate>=0.26.0

# Copy the entire project (needed for primerforge module imports and warmup validation)
COPY primerforge/ ./primerforge/
COPY azure_worker/ ./azure_worker/
COPY config/ ./config/
COPY wsgi.py .

# Pre-download ESMFold model weights (~8GB) into image to avoid cold-start download on ACI
RUN python /app/azure_worker/preload_esmfold.py 2>&1

# Validate all pipeline modules import correctly during build
RUN python /app/azure_worker/validate_build.py 2>&1

# ── Entrypoint ─────────────────────────────────────────────────────────────

# Default: print help. Users override via ACI command-line.
ENTRYPOINT ["python", "/app/azure_worker/worker.py"]
CMD ["--help"]
