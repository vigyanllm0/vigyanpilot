# ────────────────────────────────────────────────────────────────────────────
# VigyanLLM GPU Docker image (v6)
# ===========================
# CUDA-based image for GPU-accelerated ESMFold + CNN scoring (GNINA).
# Requires NVIDIA Container Toolkit on the host at runtime.
# ESMFold weights are NOT in the image — downloaded on first start.
#
# Build & push to ACR:
#   az acr build --registry vigyanregistry01 --image vigyan-worker:gpu \
#     -f azure_worker/Dockerfile.gpu .
#
# Or local build + push:
#   docker build -t vigyan-worker-gpu -f azure_worker/Dockerfile.gpu .
#   az acr login --name vigyanregistry01
#   docker tag vigyan-worker-gpu vigyanregistry01.azurecr.io/vigyan-worker:gpu
#   docker push vigyanregistry01.azurecr.io/vigyan-worker:gpu
#
# Deploy on ACI (V100 GPU, 24GB RAM, 4 CPU):
#   az container delete -g VigyanComputeGroup -n vigyan-worker-gpu --yes
#   az container create \
#     --resource-group VigyanComputeGroup \
#     --name vigyan-worker-gpu \
#     --image vigyanregistry01.azurecr.io/vigyan-worker:gpu \
#     --cpu 4 --memory 24 \
#     --gpu count=1 sku=V100 \
#     --environment-variables \
#       API_BASE_URL=https://www.vigyanllm.in \
#       POLL_INTERVAL=10 \
#       WORKER_MODE=daemon \
#     --command-line "python /app/azure_worker/worker.py"
# ────────────────────────────────────────────────────────────────────────────

FROM nvidia/cuda:12.1.0-runtime-ubuntu22.04

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    DEBIAN_FRONTEND=noninteractive \
    TORCH_LOAD_MMAP=0

# Install Python 3.11 with pip
RUN apt-get update && apt-get install -y --no-install-recommends \
    software-properties-common \
    && add-apt-repository ppa:deadsnakes/ppa \
    && apt-get install -y --no-install-recommends \
    python3.11 python3.11-venv python3.11-dev python3.11-distutils \
    && rm -rf /var/lib/apt/lists/* && \
    python3.11 -m ensurepip --upgrade && \
    python3.11 -m pip install --upgrade --ignore-installed pip setuptools wheel

# Install system dependencies for bioinformatics tools + molecular docking
RUN apt-get update && apt-get install -y --no-install-recommends \
    autodock-vina \
    bowtie2 \
    build-essential \
    ca-certificates \
    curl \
    mafft \
    ncbi-blast+ \
    openbabel \
    primer3 \
    samtools \
    tabix \
    vienna-rna \
    && rm -rf /var/lib/apt/lists/*

# Download GNINA binary (CNN docking scorer)
RUN curl -fsSL https://github.com/gnina/gnina/releases/download/v1.3/gnina -o /usr/local/bin/gnina \
    && chmod +x /usr/local/bin/gnina

WORKDIR /app

# Copy and install Python dependencies first (for Docker layer caching)
COPY requirements.txt requirements-docking.txt ./
RUN python3.11 -m pip install --no-cache-dir --ignore-installed -r requirements.txt

# Install CUDA-enabled PyTorch (for GPU ACI)
RUN python3.11 -m pip install --no-cache-dir --index-url https://download.pytorch.org/whl/cu121 "torch>=2.2.0" && \
    python3.11 -m pip install --no-cache-dir transformers>=4.40.0 tokenizers>=0.15.0 fair-esm>=2.0.0 \
                          einops>=0.6.0 accelerate>=0.26.0

# Create HuggingFace cache directory
RUN mkdir -p /root/.cache/huggingface

# Copy the entire project
COPY primerforge/ ./primerforge/
COPY azure_worker/ ./azure_worker/
COPY wsgi.py .

RUN python3.11 /app/azure_worker/validate_build.py 2>&1

ENTRYPOINT ["python3.11", "/app/azure_worker/worker.py"]
CMD ["--daemon"]
