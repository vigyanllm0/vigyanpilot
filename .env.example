# ── VigyanLLM Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in real values. Never commit .env.

# Razorpay payment gateway (get from dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX
RAZORPAY_WEBHOOK_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# Admin credentials
PRIMERFORGE_ADMIN_EMAIL=admin@yourdomain.com
PRIMERFORGE_ADMIN_PASSWORD=YourStrongPassword

# App secret (used to sign session tokens — generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
PRIMERFORGE_SECRET=your-64-char-random-hex-string

# PostgreSQL connection
DATABASE_URL=postgresql://vigyanpilot_app:YOUR_DB_PASSWORD@localhost:5432/vigyanpilot_db

# Google OAuth2 Client ID (from console.cloud.google.com)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# UPI ID for payment display
PRIMERFORGE_UPI_ID=yourname@bank

# NCBI API key (optional — increases rate limit from 3 to 10 req/sec)
# Get at: https://www.ncbi.nlm.nih.gov/account/
# NCBI_API_KEY=your-ncbi-api-key

# Data encryption key (for Fernet AES-256-CBC at-rest encryption of pipeline results)
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If not set, the key is derived from PRIMERFORGE_SECRET (SHA-256).
# DATA_ENCRYPTION_KEY=

# GISAID credentials (optional — only needed for GISAID sequence fetching)
# GISAID_USERNAME=your-username
# GISAID_PASSWORD=your-password

# Redis (optional — enables Celery background jobs and rate limiting)
# REDIS_URL=redis://localhost:6379/0

# Server binding (development only)
# PRIMERFORGE_HOST=0.0.0.0
# PRIMERFORGE_PORT=11436
# PRIMERFORGE_DEBUG=true

# ── Email Infrastructure (Hostinger SMTP) ──────────────────────────────────
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=587
# SMTP_USER=your-email@vigyanllm.in
# SMTP_PASSWORD=your-smtp-password
# SMTP_FROM_EMAIL=noreply@vigyanllm.in
# APP_URL=https://vigyanllm.com

# ── DNS Security (see deploy/dns-records.txt) ──────────────────────────────
# REQUIRED: Add these TXT records to vigyanllm.in DNS zone:
#   1. SPF:  v=spf1 mx include:_spf.hostinger.com -all
#   2. DKIM: hostinger._domainkey TXT (get key from Hostinger Email panel)
#   3. DMARC: v=DMARC1; p=quarantine; rua=mailto:dmarc@vigyanllm.in; fo=1
#   4. MX:   mx.hostinger.com (priority 0)
