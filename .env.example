# ── VigyanLLM Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to git — it is already in .gitignore.
#
# Key rotation procedure:
#   1. Generate new value (see command next to each var)
#   2. Update .env on server: `ssh ec2 && nano /path/to/.env`
#   3. Restart app: `docker-compose up -d --force-recreate app`

# ── Razorpay Payment Gateway ──────────────────────────────────────────────────
# Obtain from: https://dashboard.razorpay.com/app/keys
# Use TEST keys (rzp_test_...) locally; LIVE keys only in production .env on server.
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Webhook secret — set in Razorpay Dashboard > Webhooks > Secret
# MUST be different from RAZORPAY_KEY_SECRET. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
RAZORPAY_WEBHOOK_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Admin Credentials ─────────────────────────────────────────────────────────
# Admin account is auto-created on startup if it doesn't exist.
# Use a STRONG password (≥16 chars, uppercase, digits, special chars).
PRIMERFORGE_ADMIN_EMAIL=admin@yourdomain.com
PRIMERFORGE_ADMIN_PASSWORD=Change-This-Strong-Password-1!

# ── App Session Secret ────────────────────────────────────────────────────────
# Signs all session tokens. Changing this invalidates ALL user sessions.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(64))"
# Must be at least 64 characters of random hex.
PRIMERFORGE_SECRET=REPLACE_WITH_128_CHAR_HEX_STRING_python3_c_import_secrets_print_secrets_token_hex_64

# ── Data Encryption Key ───────────────────────────────────────────────────────
# Fernet AES-256 key for encrypting pipeline results at rest.
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If unset, derived from PRIMERFORGE_SECRET (acceptable but less isolated).
# DATA_ENCRYPTION_KEY=

# ── PostgreSQL Connection ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://vigyanpilot_app:YOUR_DB_PASSWORD@localhost:5432/vigyanpilot_db

# ── Redis (Required in Production) ───────────────────────────────────────────
# Enables: Celery background jobs, Redis-backed rate limiting (multi-worker safe)
# Set REDIS_PASSWORD to the same value as in docker-compose REDIS_PASSWORD var.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@localhost:6379/0
REDIS_PASSWORD=YOUR_REDIS_PASSWORD

# ── Google OAuth2 ─────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs: https://yourdomain.com/auth/google/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ── UPI Payment Display ───────────────────────────────────────────────────────
PRIMERFORGE_UPI_ID=yourname@bank

# ── NCBI Entrez API Key (Optional) ────────────────────────────────────────────
# Increases NCBI rate limit: 3 → 10 req/sec. Register at:
# https://www.ncbi.nlm.nih.gov/account/
# NCBI_API_KEY=your-ncbi-api-key

# ── Email (Hostinger SMTP) ────────────────────────────────────────────────────
# Required for: email verification, password reset, breach notifications
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=noreply@vigyanllm.in
SMTP_PASSWORD=YOUR_SMTP_PASSWORD
SMTP_FROM_EMAIL=noreply@vigyanllm.in
APP_URL=https://vigyanllm.com

# ── Environment Mode ──────────────────────────────────────────────────────────
# Set to "production" on server to enable HTTPS redirects, strict CSP, etc.
# Leave blank or "development" locally.
VIGYANLLM_ENV=development
# FORCE_HTTPS=true   # Uncomment on production server

# ── Server Binding ────────────────────────────────────────────────────────────
# PRIMERFORGE_HOST=0.0.0.0
# PRIMERFORGE_PORT=11436
# PRIMERFORGE_DEBUG=false

# ── Postgres Docker Password ──────────────────────────────────────────────────
# Used by deploy/docker-compose.yml — must match DATABASE_URL password.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
PGPASSWORD=YOUR_POSTGRES_PASSWORD

# ── Session Limits ────────────────────────────────────────────────────────────
# Maximum concurrent sessions per user (oldest session evicted when limit hit)
MAX_SESSIONS=5

# ── Brevo/SendinBlue (CMS backend email) ─────────────────────────────────────
# Used by backend/server.js CMS for transactional emails
# BREVO_API_KEY=your-brevo-api-key

# ── DNS Security Records ──────────────────────────────────────────────────────
# REQUIRED: Add these TXT records to vigyanllm.in DNS zone:
#   1. SPF:   v=spf1 mx include:_spf.hostinger.com -all
#   2. DKIM:  hostinger._domainkey TXT (get from Hostinger Email panel)
#   3. DMARC: v=DMARC1; p=quarantine; rua=mailto:dmarc@vigyanllm.in; fo=1
#   4. MX:    mx.hostinger.com (priority 0)
